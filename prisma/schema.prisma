// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url = env("DATABASE_URL")
}

model Category{
  id          Int       @id @default(autoincrement())
  name        String
  createdAt   DateTime  @default(now()) @map("created_at")
  events      Event[]

  @@map("categories")
}

model Speaker{
  id          Int       @id @default(autoincrement())
  name        String
  role        String
  image       String
  createdAt   DateTime  @default(now()) @map("created_at")
  events      Event[]

  @@map("speakers")
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String
  categoryId  Int      @map("category_id") // Ini Foreign Key ke Category
  location    String
  dateEvent   DateTime @map("date_event")
  description String   @db.Text            // Diubah ke @db.Text agar deskripsi tugasmu bisa panjang
  createdAt   DateTime @default(now()) @map("created_at")

  // 🌟 JEMBATAN RELASI RESMI (Wajib ditulis agar tidak error)
  category    Category @relation(fields: [categoryId], references: [id])
  speakers    Speaker[]

  @@map("events")
}